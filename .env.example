# GPU Support Training Lab
# Copy to .env and fill in your target server details
# (or just run ./setup.sh and it'll do this for you)

# debug mode -- set to true during development for verbose logging
# shows request timing, SSH commands, curriculum loading, debug banner in UI
# set to false (or remove) when you're done building
DEBUG=true

# target server -- the H100 machine you're training on
LAB_TARGET_HOST=10.0.0.1
LAB_TARGET_PORT=22
LAB_TARGET_USER=labuser
LAB_SSH_CMD=sshv

# web dashboard (runs on your laptop)
WEB_PORT=8080
TERMINAL_PORT=7681

# support-tooling repo path on your laptop
SUPPORT_TOOLING_PATH=../Support-Tooling
